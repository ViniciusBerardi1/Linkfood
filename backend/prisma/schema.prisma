generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  tipo      String   // "doador" ou "receptor"
  telefone  String?
  endereco  String?
  createdAt DateTime @default(now())
  doacoes   Doacao[] @relation("UsuarioDoador")
  pedidos   Doacao[] @relation("UsuarioReceptor")
}

model Doacao {
  id          Int      @id @default(autoincrement())
  titulo      String
  descricao   String
  quantidade  String
  validade    String?
  status      String   @default("aberto") // "aberto", "em_andamento", "concluido"
  createdAt   DateTime @default(now())
  doadorId    Int
  receptorId  Int?
  doador      Usuario  @relation("UsuarioDoador", fields: [doadorId], references: [id])
  receptor    Usuario? @relation("UsuarioReceptor", fields: [receptorId], references: [id])
}